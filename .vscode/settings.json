{
  "python.defaultInterpreterPath": "${workspaceFolder}/ai-trainer/backend/venv/Scripts/python.exe",
  "python.analysis.venvPath": "${workspaceFolder}/ai-trainer/backend",
  "python.analysis.venv": "venv",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/ai-trainer/backend",
    "${workspaceFolder}/ai-trainer/backend/venv/Lib/site-packages"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.reportMissingImports": "none",
  "python.analysis.reportMissingModuleSource": "none",
  "python.analysis.exclude": [
    "**/venv/**",
    "**/__pycache__/**",
    "**/migrations/**"
  ],
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingImports": "none",
    "reportMissingModuleSource": "none"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8"
  }
}
